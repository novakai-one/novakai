%% last updated 24th June 2026
%% root bm
%% TWO-LEVEL DRILL of BlockManager (standalone proof; merge into novakai.mmd after).
%%
%% WHY THE LAST VERSION SPREAD (read from src/io/layout.ts):
%%   placeSatellites parks every LOOSE (dotted-only) satellite at cMax + LAYER_GAP
%%   — the bottom of the ENTIRE global spine. The spine is tall (12 workers
%%   stacked), so that band is far below bm. Top-level satellites therefore
%%   render far from bm in the top crop. FIX, both from the code:
%%     1. parent every dependency into the level where it is used, so the TOP
%%        crop is just bm (one node) — nothing left to spread.
%%     2. put each satellite inside a subgraph that also holds spine nodes.
%%        layout.ts INLINES a mixed-group satellite beside a groupmate (inlineSet)
%%        instead of far-parking it. So no satellite is loose -> none get flung.
%%
%% LEVELS:
%%   top                   : blockManager (one node)
%%   drill blockManager    : routers / holders(+payloadIO) / context, blockWorkers.ts, blockCommit.ts
%%   drill blockWorkers.ts : 10 builders + dbBuild section (db builders + factory/type)
%%   drill blockCommit.ts  : the 2 committers
%%
%% SPINE (solid): bm -> routers -> holders -> {blockWorkers, blockCommit} -> functions
%% REFERENCES (dotted): payload IO, db structures, type use, downstream — all sit
%%   inside a mixed subgraph so they inline tight.
%%
%% ── BlockManager — root / only top-level node ────────────────────────────────
%% fm:meta bm name=BlockManager
%% fm:meta bm desc=conduit helper owning block create + delete; DocDraft in / DocDraft out; routers pass the Payload, holders decide; states placement, never resolves collisions, never touches caret
%% fm:meta bm i0.name=receiveMouseEvent
%% fm:meta bm i0.accepts=draft: DocDraft
%% fm:meta bm i0.returns=DocDraft
%% fm:meta bm i1.name=receiveKeyEvent
%% fm:meta bm i1.accepts=draft: DocDraft
%% fm:meta bm i1.returns=DocDraft
%% fm:meta bm i2.name=receiveLifecycleEvent
%% fm:meta bm i2.accepts=draft: DocDraft
%% fm:meta bm i2.returns=DocDraft
%% ── Routers (section, BM drill level) ────────────────────────────────────────
