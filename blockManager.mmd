  bm["BlockManager"]
  blockWorkers["blockWorkers.ts"]
  blockCommit["blockCommit.ts"]
  makeBlock("makeContentBlock")
  buildClickBlock("buildClickBlock")
  buildBottomBlock("buildBottomBlock")
  buildBelowBlock("buildBelowBlock")
  toggleValue("toggleValue")
  diffText("diffText")
  removeBlock("removeBlock")
  lowest("lowestPlacedBottom")
  insertAfter("insertAfter")
  placementFor("placementFor")
  addBlock("addBlock")
  writeSlices("writeSlices")
  subgraph routers ["Routers — public receive*; pass DocDraft, pick intent"]
    rMouse{"receiveMouseEvent"}
    rKey{"receiveKeyEvent"}
    rLife{"receiveLifecycleEvent"}
  end
  subgraph holders ["Logic holders + payload IO"]
    createBlock("createBlock")
    deleteBlock("deleteBlock")
    addRow("addRow")
    toggleCell("toggleCell")
    commitText("commitText")
    payloadIO("draftToFlat / foldIntoDraft")
  end
  subgraph context ["Collaborator / payload / downstream"]
    blockDefs["blockDefinitions"]
    docDraft>"DocDraft (Payload)"]
    layoutMgr{{"LayoutManager (next in chain)"}}
  end
  subgraph dbBuild ["DB builders"]
    buildDatabase("buildDatabase")
    buildRow("buildRow")
    dbFactory["databaseFactory"]
    registryKey>"ComponentRegistryKey"]
  end
  %% ── SPINE level 0->1: bm -> routers ; bm -> blockDefs (collaborator) ────────
  bm -->|mouse| rMouse
  bm -->|key| rKey
  bm -->|lifecycle| rLife
  bm -->|resolves spec| blockDefs
  %% ── SPINE level 1: routers -> holders ──────────────────────────────────────
  rMouse -->|workspace / panel click = create| createBlock
  rMouse -->|database-add-row| addRow
  rMouse -->|cell-toggle| toggleCell
  rKey -->|Enter / Cmd+Shift+D = create| createBlock
  rKey -->|Backspace = delete| deleteBlock
  rLife -->|blur / input = commit| commitText
  %% ── SPINE level 1->2: holders -> the two .ts modules ───────────────────────
  createBlock -->|build| blockWorkers
  createBlock -->|commit| blockCommit
  deleteBlock -->|build| blockWorkers
  deleteBlock -->|commit| blockCommit
  addRow -->|build| blockWorkers
  addRow -->|commit| blockCommit
  toggleCell -->|build| blockWorkers
  toggleCell -->|commit| blockCommit
  commitText -->|build| blockWorkers
  commitText -->|commit| blockCommit
  %% ── SPINE inside blockWorkers.ts: module -> builders -> shared leaves ───────
  blockWorkers -->|create variant| buildClickBlock
  blockWorkers -->|create variant| buildBottomBlock
  blockWorkers -->|create variant| buildBelowBlock
  blockWorkers -->|database variant| buildDatabase
  blockWorkers -->|delete| removeBlock
  blockWorkers -->|db row| buildRow
  blockWorkers -->|cell flip| toggleValue
  blockWorkers -->|text diff| diffText
  blockWorkers -->|measure| lowest
  blockWorkers -->|order| insertAfter
  buildClickBlock -->|uses| makeBlock
  buildBottomBlock -->|uses| makeBlock
  buildBelowBlock -->|uses| makeBlock
  buildClickBlock -->|places| placementFor
  buildBottomBlock -->|places| placementFor
  buildBelowBlock -->|places| placementFor
  buildDatabase -->|places| placementFor
  %% ── SPINE inside blockCommit.ts ────────────────────────────────────────────
  blockCommit -->|add path| addBlock
  blockCommit -->|slice path| writeSlices
  %% ── REFERENCES (dotted): all endpoints sit in a mixed subgraph -> inline ────
  bm -.->|receives / returns| docDraft
  docDraft -.->|then resolves collisions| layoutMgr
  createBlock -.->|draftToFlat / foldIntoDraft| payloadIO
  deleteBlock -.->|draftToFlat / foldIntoDraft| payloadIO
  addRow -.->|draftToFlat / foldIntoDraft| payloadIO
  toggleCell -.->|draftToFlat / foldIntoDraft| payloadIO
  commitText -.->|draftToFlat / foldIntoDraft| payloadIO
  createBlock -.->|panel spec lookup| blockDefs
  createBlock -.->|lowest bottom| lowest
  createBlock -.->|order after source| insertAfter
  buildDatabase -.->|db structures| dbFactory
  buildRow -.->|db structures| dbFactory
  makeBlock -.->|component type| registryKey
  buildDatabase -.->|component type| registryKey
