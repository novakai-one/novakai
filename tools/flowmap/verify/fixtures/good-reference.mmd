%% fm:meta storage__saveContent name=saveContentData
%% fm:meta storage__saveContent desc=content-only; merges new content with cachedDoc files/layouts/databases (no network read)
%% fm:meta storage__clear name=clearDocument
%% fm:meta storage__clear desc=set document column null for the user
