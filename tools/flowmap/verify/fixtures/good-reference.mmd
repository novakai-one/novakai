%% fm:meta selection__range desc=range/range; selection points in document order
%% fm:meta selection__clip name=clipboard.receiveEvent
%% fm:meta selection__clip desc=ClipboardManager; threads every event, no-ops unless clipboard trigger
%% fm:meta selection__route name=router
%% fm:meta selection__route desc=core/router; routeMouse/Key/Lifecycle update selection state
%% fm:meta selection__paint name=applyHighlights
%% fm:meta selection__paint desc=renderSelectionHighlight; CSS.highlights only, no state, no re-render
%% fm:meta selection__shape name=buildShape
%% fm:meta selection__shape desc=core/shapeBuilder; writes clipboard result + selection + snapshot into DocShape
%% fm:meta selection__snap name=computeSnapshot
%% fm:meta selection__snap desc=returns the SAME reference when unchanged -> WSA does not re-render
%% fm:meta selection__selIds name=computeSelectedIds
%% fm:meta selection__selIds desc=multi-block mode only; mapped from range
%% fm:meta selection__caret name=computeCaret
%% fm:meta selection__caret desc=collapsed caret only; blockId + offset
%% fm:meta selection__sameSnap name=sameSnapshot
%% fm:meta selection__sameSnap desc=value equality that enables the stable reference
