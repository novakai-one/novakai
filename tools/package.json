{
  "name": "flowmap-spec-tools",
  "version": "0.1.0",
  "description": "Flowmap spec tooling: bundle per-folder .mmd fragments, extract a diagram + source bodies from TypeScript, and gate code against the spec to make AI drift impossible. Ships the authoring spec (SYNTAX_README.md).",
  "type": "module",
  "bin": {
    "flowmap-bundle": "flowmap/bundle.mjs",
    "flowmap-validate": "flowmap/validate.mjs",
    "flowmap-extract": "buildspec/extract.mjs",
    "flowmap-gate": "buildspec/gate.mjs",
    "flowmap-stubs": "buildspec/spec-to-stubs.mjs"
  },
  "files": [
    "flowmap/bundle.mjs",
    "flowmap/validate.mjs",
    "buildspec/extract.mjs",
    "buildspec/gate.mjs",
    "buildspec/spec-to-stubs.mjs",
    "buildspec/mmd-parse.mjs",
    "buildspec/skeleton.mjs",
    "buildspec/diff-core.mjs",
    "SYNTAX_README.md",
    "README.md"
  ],
  "dependencies": {
    "ts-morph": "^28.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
