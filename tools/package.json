{
  "name": "novakai-spec-tools",
  "version": "0.1.0",
  "description": "Novakai spec tooling: bundle fragments, extract a diagram + source bodies from TypeScript, gate code against the spec, and lint a .mmd for structural quality (sections, decomposition) so an AI can self-verify it built a real architecture map, not a flat file-mirror. Ships the authoring spec (SYNTAX_README.md).",
  "type": "module",
  "bin": {
    "novakai-bundle": "novakai/bundle.mjs",
    "novakai-validate": "novakai/validate.mjs",
    "novakai-extract": "buildspec/pipeline/extract.mjs",
    "novakai-gate": "buildspec/pipeline/gate.mjs",
    "novakai-stubs": "buildspec/pipeline/spec-to-stubs.mjs",
    "novakai-scaffold": "buildspec/scaffold/scaffold.mjs",
    "novakai-lint": "novakai/novakai-lint.mjs"
  },
  "files": [
    "novakai/bundle.mjs",
    "novakai/validate.mjs",
    "novakai/novakai-lint.mjs",
    "buildspec/pipeline/extract.mjs",
    "buildspec/pipeline/gate.mjs",
    "buildspec/pipeline/spec-to-stubs.mjs",
    "buildspec/core/mmd-parse.mjs",
    "buildspec/core/skeleton.mjs",
    "buildspec/core/diff-core.mjs",
    "buildspec/scaffold/scaffold.mjs",
    "SYNTAX_README.md",
    "README.md",
    "BUILD_NOVAKAI.md",
    "novakai/novakai-lint.test.mjs",
    "novakai/novakai-lint.discriminate.test.mjs",
    "novakai/fixtures/"
  ],
  "dependencies": {
    "ts-morph": "^28.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "scripts": {
    "test": "node novakai/novakai-lint.test.mjs && node novakai/novakai-lint.discriminate.test.mjs",
    "prepublishOnly": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/novakai-one/novakai.git",
    "directory": "tools"
  }
}
