{
  "name": "flowmap",
  "version": "1.0.0",
  "description": "A spatial diagram tool for dev work — drag-and-drop flowcharts with two-way Mermaid sync, themes, and exports.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "spec:stubs": "node tools/buildspec/spec-to-stubs.mjs",
    "spec:extract": "node tools/buildspec/extract.mjs",
    "spec:gate": "node tools/buildspec/gate.mjs",
    "spec:test": "node --test tools/buildspec/pipeline.test.mjs"
  },
  "devDependencies": {
    "ts-morph": "^28.0.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@mr_mint/elkjs-libavoid": "^0.5.0"
  }
}
