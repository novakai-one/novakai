  subgraph construct ["Construct + normalize"]
    emptyFrontmatter("emptyFrontmatter")
    emptyInterface("emptyInterface")
    normalizeFrontmatter("normalizeFrontmatter")
    isFrontmatterEmpty("isFrontmatterEmpty")
    pruneFrontmatter("pruneFrontmatter")
  end
  subgraph serialize ["Serialize <-> Mermaid"]
    frontmatterToMermaid("frontmatterToMermaid")
    matchFrontmatterLine("matchFrontmatterLine")
    applyFrontmatterLine("applyFrontmatterLine")
  end
  subgraph typexref ["Type cross-reference"]
    parseTypeRef("parseTypeRef")
    frontmatterTypeNames("frontmatterTypeNames")
    nodeUsesType("nodeUsesType")
