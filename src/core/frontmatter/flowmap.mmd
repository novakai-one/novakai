  frontmatter["frontmatter"]
  frontmatter -->|i0 normalize| normalizeFrontmatter
  frontmatter -->|i1 serialize| frontmatterToMermaid
  frontmatter -->|i2 type names| allTypeNames
  normalizeFrontmatter -.->|seeds| emptyFrontmatter
  emptyFrontmatter -.->|each iface| emptyInterface
  pruneFrontmatter -.->|skips| isFrontmatterEmpty
  applyFrontmatterLine -.->|parsed by| matchFrontmatterLine
  applyFrontmatterLine -.->|into| emptyFrontmatter
  frontmatterTypeNames -.->|splits each| parseTypeRef
  nodeUsesType -.->|scans| frontmatterTypeNames
  allTypeNames -.->|per node| frontmatterTypeNames
  parseTypeRef -.->|returns| TypeRef
  frontmatter -.->|over Frontmatter| types
