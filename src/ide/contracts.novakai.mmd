%% root contracts

%% ---- contracts.ts: the tab factory + read-only artifact shapes ----

%% src ContractsApi src/ide/contracts.ts#ContractsApi
%% kind ContractsApi type
%% fm:meta ContractsApi desc=what contracts.ts exposes to main.ts/shell.ts — render(): HTMLElement, the house tab-module shape
%% fm:meta ContractsApi i0.name=render
%% fm:meta ContractsApi i0.returns=HTMLElement

%% src PlanChangeTarget src/ide/contracts.ts#PlanChangeTarget
%% kind PlanChangeTarget type
%% fm:meta PlanChangeTarget desc=a change's target: kind + ref (the symbol/file the build touches), rendered as a card meta chip (SPEC_CONTRACTS.md §3)

%% src PlanChangeIntent src/ide/contracts.ts#PlanChangeIntent
%% kind PlanChangeIntent type
%% fm:meta PlanChangeIntent desc=the plain-language layer — problem/approach/rationale (+ optional alternative/tradeoff); the document's intent section, plain first (§4)

%% src PlanChangeAcceptanceCase src/ide/contracts.ts#PlanChangeAcceptanceCase
%% kind PlanChangeAcceptanceCase type
%% fm:meta PlanChangeAcceptanceCase desc=one named acceptance case declared in the plan; joined with the verdict's per-case pass/fail in the document (§4)

%% src PlanChange src/ide/contracts.ts#PlanChange
%% kind PlanChange type
%% fm:meta PlanChange desc=one change entry in public/plan.json — a "build". id/status/phase/risk/target/intent/acceptance; the list is plan.changes[] (§1)

%% src Plan src/ide/contracts.ts#Plan
%% kind Plan type
%% fm:meta Plan desc=the plan.json shape: base + changes[]; fetched once per render pass, the list page's whole data source (§1)

%% src PacketSignatureIface src/ide/contracts.ts#PacketSignatureIface
%% kind PacketSignatureIface type
%% fm:meta PacketSignatureIface desc=one interface of a packet signature — name + accepts[] + returns[]; the technical layer's type detail (§4)

%% src PacketSignature src/ide/contracts.ts#PacketSignature
%% kind PacketSignature type
%% fm:meta PacketSignature desc=the packet's signature block — name/description/interfaces[]; the technical layer, one toggle deep (§4)

%% src PacketSource src/ide/contracts.ts#PacketSource
%% kind PacketSource type
%% fm:meta PacketSource desc=where the change binds in code — path + symbol; rendered as path::symbol in the technical layer (§4)

%% src SubMapNode src/ide/contracts.ts#SubMapNode
%% kind SubMapNode type
%% fm:meta SubMapNode desc=one node of the packet's impact sub-map — id/kind/optional parent; a node in the hand-laid impact-slice SVG (§4)

%% src SubMapEdge src/ide/contracts.ts#SubMapEdge
%% kind SubMapEdge type
%% fm:meta SubMapEdge desc=one edge of the packet's impact sub-map — from/to/optional label; an edge in the impact-slice SVG (§4)

%% src ContractPacket src/ide/contracts.ts#ContractPacket
%% kind ContractPacket type
%% fm:meta ContractPacket desc=the novakai:contract output the document reads — intent/signature/source/contractHash/deps/coherence/blastRadius/subMap; absent fields render the honest dim state (§4)

%% src VerdictCase src/ide/contracts.ts#VerdictCase
%% kind VerdictCase type
%% fm:meta VerdictCase desc=one behavioural case's result — name + pass; rendered as ink pass/fail text, never a green dot (§4/§6)

%% src Verdict src/ide/contracts.ts#Verdict
%% kind Verdict type
%% fm:meta Verdict desc=the novakai:verify-change output — structural.status + behavioural counts/cases + PASS/PASS_UNPROVEN/FAIL + verdictHash; fills the trust seal honestly (§5)

%% src BuildRow src/ide/contracts.ts#BuildRow
%% kind BuildRow type
%% fm:meta BuildRow desc=one build = a plan change joined with its optional packet + verdict; the unit both the list and the document render (§1)

%% src initContracts src/ide/contracts.ts#initContracts
%% kind initContracts function
%% fm:meta initContracts desc=the K4 Contracts tab factory — read-only: index-first fetch of plan/packet/verdict, list render with DONE/needs-you grouping, in-page swap to the certificate document; never invokes tooling, never mutates state
%% fm:meta initContracts i0.name=initContracts
%% fm:meta initContracts i0.accepts=ctx: AppContext
%% fm:meta initContracts i0.returns=ContractsApi

%% ---- contracts-doc.ts: the per-build certificate document ----

%% src renderDocument src/ide/contracts-doc.ts#renderDocument
%% kind renderDocument function
%% fm:meta renderDocument desc=build the read-only certificate document for one build — header, trust seal (keystone rule), intent, technical layer, contract + impact slice, acceptance, honest-empty activity; every value traceable to a fetched artifact JSON path
%% fm:meta renderDocument i0.name=renderDocument
%% fm:meta renderDocument i0.accepts=row: BuildRow
%% fm:meta renderDocument i0.accepts=planBase: string
%% fm:meta renderDocument i0.returns=HTMLElement

