%% fm:meta resolveDom desc=resolve required DOM elements by id (stage, world, wires, mmd, main)

%% kind buildContext function
%% fm:meta buildContext name=build AppContext
%% fm:meta buildContext desc=construct the single ctx: model, camera, prefs, history, clipboard, runtime, hooks

%% kind initModules function
%% fm:meta initModules name=instantiate modules
%% fm:meta initModules desc=call each initX in dependency order, passing ctx and the deps it needs

%% kind wireHooks function
%% fm:meta wireHooks name=wire hooks
%% fm:meta wireHooks desc=assign real implementations onto ctx.hooks so modules call each other cycle-free

%% kind bindToolbar function
%% fm:meta bindToolbar name=bind toolbar DOM
%% fm:meta bindToolbar desc=bind shape tools, link, undo/redo, tidy, export, save, zoom and help controls

%% kind loadOrSeed function
%% fm:meta loadOrSeed name=load prefs + restore or seed
%% fm:meta loadOrSeed desc=load prefs, restore autosave or seed the sample diagram, apply theme and camera

%% kind firstRender function
%% fm:meta firstRender name=first render
%% fm:meta firstRender desc=render, breadcrumb, mermaid sync, baseline history, then resolve the boot surface (resolveBootSurface: sticky, default read — open the reading overlay when it wins, M4) and load optional bodies.json

