%% src ufDrawWires src/panel/unfold.ts#drawWires
%% kind ufDrawWires function
%% fm:meta ufDrawWires name=drawWires
%% fm:meta ufDrawWires desc=paint the pure lift decision (ufLiftWires): wires run between sibling anchors under their lowest common container so no wire crosses a foreign group box; concealed counts render as mid-path badges; arrowheads exist only on atomic reveals (selected leaf / exploded wire); hot wires keep the accent + flow grammar; weight ramp, hub fade and hit paths operate on the lifted set
%% fm:meta ufDrawWires i0.name=drawWires
%% fm:meta ufDrawWires i0.returns=void

%% src ufLiftWires src/panel/unfold-lift.ts#ufLiftWires
%% kind ufLiftWires function
%% fm:meta ufLiftWires name=liftWires
%% fm:meta ufLiftWires desc=pure wire-picture decision for the primary surface: every wire lifts to sibling anchors under the lowest common container (never crossing a foreign boundary), concealed endpoints counted for the badge; the lowest selected point sets the travel depth — a selected leaf reveals true wires (atomic, arrowed, hot), a selected container anchors its crossing wires at its own border (hot), a selected wire explodes into its underlying relations; opposite directions merge (weight-majority orientation) since arrowheads exist only on atomic reveals
%% fm:meta ufLiftWires i0.name=ufLiftWires
%% fm:meta ufLiftWires i0.accepts=edges: LiftEdge[]
%% fm:meta ufLiftWires i0.accepts=spec: LiftSpec
%% fm:meta ufLiftWires i0.returns=LiftedWire[]

