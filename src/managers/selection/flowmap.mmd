%% root selection
%% AUTHORED FROM src/managers/selection/selection/NEWSelectionManager.ts
%% submodules (router, shapeBuilder, highlightRenderer, range, clipboard) mapped as PRIVATE internals; promote to root if they later get their own flowmap.mmd
%% --- container (canonical public contract) ---
%% fm:meta selection name=NewSelectionManager
%% fm:meta selection desc=uniform 3-channel selection; threads clipboard, routes, paints, writes SelectionSnapshot into the shape
%% --- doors ---
%% fm:meta selMouse name=receiveMouseEvent
%% fm:meta selMouse desc=mouse channel
%% fm:meta selKey name=receiveKeyEvent
%% fm:meta selKey desc=key channel; delete cuts span using pre-route selection
%% fm:meta selLife name=receiveLifecycleEvent
%% fm:meta selLife desc=lifecycle channel (focus/blur)
%% --- translators (flat actions) ---
%% fm:meta mouseFlat name=_receiveMouseFlat
%% fm:meta keyFlat name=_receiveKeyFlat
%% fm:meta keyFlat desc=reads isDeleteKey; passes deleting flag to buildShape
%% fm:meta lifeFlat name=_receiveLifecycleFlat
%% --- uniform body (shared pipeline) ---
%% fm:meta order name=blockOrder
%% fm:meta order desc=document order = active file content id list
%% fm:meta range name=orderedSelectionRange
%% fm:meta range desc=range/range; selection points in document order
%% fm:meta clip name=clipboard.receiveEvent
%% fm:meta clip desc=ClipboardManager; threads every event, no-ops unless clipboard trigger
%% fm:meta route name=router
%% fm:meta route desc=core/router; routeMouse/Key/Lifecycle update selection state
%% fm:meta paint name=applyHighlights
%% fm:meta paint desc=renderSelectionHighlight; CSS.highlights only, no state, no re-render
%% fm:meta shape name=buildShape
%% fm:meta shape desc=core/shapeBuilder; writes clipboard result + selection + snapshot into DocShape
%% --- snapshot (stable ref machinery) ---
%% fm:meta snap name=computeSnapshot
%% fm:meta snap desc=returns the SAME reference when unchanged -> WSA does not re-render
%% fm:meta selIds name=computeSelectedIds
%% fm:meta selIds desc=multi-block mode only; mapped from range
%% fm:meta caret name=computeCaret
%% fm:meta caret desc=collapsed caret only; blockId + offset
%% fm:meta sameSnap name=sameSnapshot
%% fm:meta sameSnap desc=value equality that enables the stable reference
%% --- deps (external; canonical defs live in root.mmd) ---
%% fm:meta DocDraft name=DocDraft
%% fm:meta DocShape name=DocShape
%% --- kinds ---
%% kind selection class
%% kind selMouse function
%% kind selKey function
%% kind selLife function
%% kind mouseFlat function
%% kind keyFlat function
%% kind lifeFlat function
%% kind order function
%% kind range function
%% kind clip function
