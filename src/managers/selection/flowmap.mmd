%% kind sameSnap function
%% kind DocDraft type
%% kind DocShape type
%% --- containment ---
%% parent doors selection
%% parent translate selection
%% parent body selection
%% parent snapshot selection
  subgraph doors ["Receivers (public interface)"]
    selMouse("receiveMouseEvent")
    selKey("receiveKeyEvent")
    selLife("receiveLifecycleEvent")
  end
  subgraph translate ["Translate — draft to flat per channel"]
    mouseFlat("_receiveMouseFlat")
    keyFlat("_receiveKeyFlat")
    lifeFlat("_receiveLifecycleFlat")
  end
  subgraph body ["Uniform body — order to range to clipboard to route to paint to shape"]
    order("blockOrder")
    range("orderedSelectionRange")
    clip("clipboard.receiveEvent")
    route("router")
    paint("applyHighlights")
    shape("buildShape")
  end
  subgraph snapshot ["Snapshot — stable ref when unchanged"]
    snap("computeSnapshot")
    selIds("computeSelectedIds")
    caret("computeCaret")
    sameSnap("sameSnapshot")
  end
  subgraph deps ["Dependencies (external)"]
    DocDraft>"DocDraft"]
    DocShape>"DocShape"]
  end
  selection["NewSelectionManager"]
  selection -->|i0 mouse| selMouse
  selection -->|i1 key| selKey
  selection -->|i2 lifecycle| selLife
  selMouse -->|draftToFlat| mouseFlat
  selKey -->|draftToFlat| keyFlat
  selLife -->|draftToFlat| lifeFlat
  mouseFlat -->|1 order| order
  mouseFlat -->|2 range| range
  mouseFlat -->|3 clipboard| clip
  mouseFlat -->|4 routeMouse| route
  mouseFlat -->|5 paint| paint
  mouseFlat -->|6 snapshot| snap
  mouseFlat -->|7 shape| shape
  keyFlat -->|1 order| order
  keyFlat -->|2 range| range
  keyFlat -->|3 clipboard| clip
  keyFlat -->|4 routeKey| route
  keyFlat -->|5 paint| paint
  keyFlat -->|6 snapshot| snap
  keyFlat -->|7 shape +deleting| shape
  lifeFlat -->|1 order| order
  lifeFlat -->|2 range| range
  lifeFlat -->|3 clipboard| clip
  lifeFlat -->|4 routeLifecycle| route
  lifeFlat -->|5 paint| paint
  lifeFlat -->|6 snapshot| snap
  lifeFlat -->|7 shape| shape
  snap -->|ids| selIds
  snap -->|caret| caret
  snap -.->|stable ref check| sameSnap
  selIds -.->|uses| range
  snap -.->|passed into| shape
  selection -.->|in/out| DocDraft
  order -.->|reads file.content| DocShape
  shape -.->|writes snapshot into| DocShape
