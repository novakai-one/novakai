    pasteIntoText("pasteIntoText")
    pasteShared("pasteShared")
    clipSelectionRange("selectionRange")
    serialize("serialize")
  end

  %% ── spine: SM orchestrates its helpers (fan-out, sequence in labels) ────────
  sm -->|1 clipboard| clipMgr
  sm -->|2 route| router
  sm -->|3 paint| highlightRenderer
  sm -->|4 build| shapeBuilder
  sm -->|range| range

  %% router fans out to its channel handlers
  router -->|mouse| mouseHandlers
  router -->|key| keyHandlers
  router -->|lifecycle| lifecycleHandlers

  %% keyHandlers dispatches to caret / extend actions
  keyHandlers -->|plain arrows| caretNavigation
  keyHandlers -->|shift / select-all| selectionExtend

  %% clipboard manager fans out to its commands
  clipMgr -->|c| copy
  clipMgr -->|x| cut
  clipMgr -->|v| paste

  %% paste router delegates to one strategy
  paste -->|text| pasteIntoText
  paste -->|blocks| pasteAsBlocks

  %% ── references (dotted): reads, type-use, write-backs, shared helpers ───────
  sm -.->|isDeleteKey| keyHandlers
  sm -.->|emptySelection + SelectionState| selectionState
  sm -.->|draftToFlat / foldIntoDraft| docShape
  sm -.->|event types| eventData

  router -.->|state type| selectionState
  router -.->|event types| eventData
  shapeBuilder -.->|orderedSelectionRange| range
  shapeBuilder -.->|state type| selectionState
  shapeBuilder -.->|DocShape type| docShape

  mouseHandlers -.->|pointToPosition| domHelpers
  mouseHandlers -.->|state type| selectionState
  keyHandlers -.->|state type| selectionState
  keyHandlers -.->|event types| eventData
  lifecycleHandlers -.->|state type| selectionState
  caretNavigation -.->|getElementText| domHelpers
  caretNavigation -.->|collapse + state| selectionState
  selectionExtend -.->|getElementText| domHelpers
  selectionExtend -.->|state type| selectionState
  highlightRenderer -.->|blockElementById / textNodeAtOffset| domHelpers
  highlightRenderer -.->|state type| selectionState
  range -.->|point types| selectionState
  domHelpers -.->|SelectionPoint type| selectionState

  %% clipboard internals
  clipMgr -.->|SelectionPoint type| selectionState
  clipMgr -.->|ClipboardMode type| clipboardStore
  copy -.->|hold| clipboardStore
  copy -.->|resolveSelectedIds| clipSelectionRange
  copy -.->|SelectionPoint type| selectionState
  cut -.->|hold| clipboardStore
  cut -.->|buildSlice| copy
  cut -.->|resolveSelectedIds| clipSelectionRange
  cut -.->|SelectionPoint type| selectionState
  paste -.->|read buffer| clipboardStore
  paste -.->|activeFileId| pasteShared
  pasteAsBlocks -.->|mode + slice| clipboardStore
  pasteAsBlocks -.->|regenerateIds| ids
  pasteAsBlocks -.->|insert helpers| pasteShared
  pasteIntoText -.->|read + range| clipboardStore
  pasteIntoText -.->|freshId| ids
  pasteIntoText -.->|insert helpers| pasteShared
  pasteIntoText -.->|SelectionPoint type| selectionState
  clipboardStore -.->|SelectionPoint type| selectionState
  clipSelectionRange -.->|SelectionPoint type| selectionState
  serialize -.->|ClipboardSlice type| clipboardStore
