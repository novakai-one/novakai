  deleteBlock -.->|fold pattern| writeSlices
  toggleCell -.->|fold pattern| writeSlices
  commitText -.->|fold pattern| writeSlices
  blockManager -.->|in/out| DocDraft
  writeSlices -.->|on| DocShape
  setDefaults -.->|makeTextElement| model
  setXYWH -.->|layoutKey| model
  updateProposed -.->|databaseKey| model
  toggleCell -.->|CHECKBOX_CHECKED| model
