%% last updated 23rd June 2026
%% root bm
%% VARIATION B — drill-in containment (%% parent).
%% Strategy: keep ONE top-level BlockManager node, but trim its card to the
%% PUBLIC conduit surface only (setWorkspaceEl + the three receive* entry points
%% + createDatabase). Every private handler and pure helper is pushed one level
%% DOWN via `%% parent <child> bm`, so they vanish from the top level and appear
%% only when you drill into BlockManager. The reader sees the public interface
%% collapsed; opening the unit reveals the implementation graph (router -> handler
%% -> builder) wired with its own edges. Edges from an inner node to an off-level
%% endpoint (blockDefinitions, the externals) draw as labelled boundary stubs.
%% This is the README §8 "unit at two levels" pattern and the most direct fix for
%% the one-giant-card problem.

%% ── BlockManager — TOP LEVEL: public surface only ───────────────────────────
%% fm:meta bm name=BlockManager
%% fm:meta bm desc=conduit helper owning block creation + deletion; WSA forwards every event as a uniform DocDraft and gets it back; LayoutManager tidies after
%% fm:meta bm state=_wsaEl: HTMLElement | null
%% fm:meta bm i0.name=setWorkspaceEl
%% fm:meta bm i0.accepts=el: HTMLElement | null
%% fm:meta bm i0.returns=void
%% fm:meta bm i1.name=receiveMouseEvent
%% fm:meta bm i1.accepts=draft: DocDraft
%% fm:meta bm i1.returns=DocDraft
%% fm:meta bm i2.name=receiveKeyEvent
%% fm:meta bm i2.accepts=draft: DocDraft
%% fm:meta bm i2.returns=DocDraft
%% fm:meta bm i3.name=receiveLifecycleEvent
%% fm:meta bm i3.accepts=draft: DocDraft
%% fm:meta bm i3.returns=DocDraft
%% fm:meta bm i4.name=createDatabase
%% fm:meta bm i4.accepts=shape: DocShape
%% fm:meta bm i4.returns=DocShape

%% ── INNER LEVEL (drill into bm): routers ─────────────────────────────────────
%% fm:meta rMouse name=_receiveMouseFlat
%% fm:meta rMouse desc=switches on the mouse trigger word and calls the matching handler
%% fm:meta rMouse i0.accepts=mouseData: MouseEventData, trigger: string, shape: DocShape
%% fm:meta rMouse i0.returns=DocShape
%% fm:meta rKey name=_receiveKeyFlat
%% fm:meta rKey desc=keydown router; Cmd+Shift+D shortcut, else Enter / Backspace
%% fm:meta rKey i0.accepts=keyData: KeyEventData, trigger: string, shape: DocShape
%% fm:meta rKey i0.returns=DocShape
%% fm:meta rLife name=_receiveLifecycleFlat
%% fm:meta rLife desc=routes blur / input triggers to the text commit
%% fm:meta rLife i0.accepts=data: LifecycleEventData, trigger: string, shape: DocShape
%% fm:meta rLife i0.returns=DocShape

%% ── INNER LEVEL: handlers ────────────────────────────────────────────────────
%% fm:meta atClick name=_createAtClick
%% fm:meta atClick desc=plain left click -> fresh empty paragraph on the clicked grid row
%% fm:meta atClick i0.accepts=mouseData: MouseEventData, shape: DocShape
%% fm:meta atClick i0.returns=DocShape
%% fm:meta fromPanel name=_createFromPanel
%% fm:meta fromPanel desc=resolves the panel click's id to a spec, routes database vs plain block
%% fm:meta fromPanel i0.accepts=mouseData: MouseEventData, shape: DocShape
%% fm:meta fromPanel i0.returns=DocShape
%% fm:meta atBottom name=_createAtBottom
%% fm:meta atBottom desc=drops a spec'd block below everything in the active file
%% fm:meta atBottom i0.accepts=spec: BlockSpec, shape: DocShape
%% fm:meta atBottom i0.returns=DocShape
%% fm:meta below name=_createBelow
%% fm:meta below desc=Enter -> commit source text then open a new block flush beneath it
%% fm:meta below i0.accepts=keyData: KeyEventData, shape: DocShape
%% fm:meta below i0.returns=DocShape
%% fm:meta addBlock name=_addBlock
%% fm:meta addBlock desc=shared mutation; folds one block + placement + content order into the shape
%% fm:meta addBlock i0.accepts=shape: DocShape, block: TextElement, placement: LayoutItem, content: string[]
%% fm:meta addBlock i0.returns=DocShape
%% fm:meta del name=_deleteBlock
%% fm:meta del desc=Backspace on an empty block -> removes it from every dataset
%% fm:meta del i0.accepts=keyData: KeyEventData, shape: DocShape
%% fm:meta del i0.returns=DocShape
%% fm:meta addRow name=_addRow
%% fm:meta addRow desc=appends one empty row (one cell block per column) to a database
%% fm:meta addRow i0.accepts=mouseData: MouseEventData, shape: DocShape
%% fm:meta addRow i0.returns=DocShape
%% fm:meta toggle name=_toggleCell
%% fm:meta toggle desc=flips a checkbox cell's innerContent between checked and empty
%% fm:meta toggle i0.accepts=mouseData: MouseEventData, shape: DocShape
%% fm:meta toggle i0.returns=DocShape
%% fm:meta createDb name=createDatabase
%% fm:meta createDb desc=public entry + its implementation; builds TextElement + LayoutItem + DatabaseConfiguration with seed cells in one commit
%% fm:meta createDb i0.accepts=shape: DocShape
%% fm:meta createDb i0.returns=DocShape
%% fm:meta commit name=_commitText
%% fm:meta commit desc=reads the live editable, writes innerContent + tag only when changed
%% fm:meta commit i0.accepts=data: LifecycleEventData, shape: DocShape
%% fm:meta commit i0.returns=DocShape

%% ── INNER LEVEL: builders / DOM readers ──────────────────────────────────────
%% fm:meta lowest name=lowestPlacedBottom
%% fm:meta lowest desc=bottom edge of the lowest placement on a file
%% fm:meta lowest i0.accepts=fileId: string, layouts: LayoutDataSet
%% fm:meta lowest i0.returns=number
%% fm:meta makeBlock name=makeBlock
%% fm:meta makeBlock desc=builds a fresh TextElement record
%% fm:meta makeBlock i0.accepts=id: string, component: TextElement.component, tag: TextElement.Tag, innerContent: string, classNames: string
%% fm:meta makeBlock i0.returns=TextElement
%% fm:meta insertAfter name=insertAfter
%% fm:meta insertAfter desc=inserts ids directly after an anchor in document order
%% fm:meta insertAfter i0.accepts=content: string[], anchorId: string, ids: string[]
%% fm:meta insertAfter i0.returns=string[]
%% fm:meta readEditable name=readEditable
%% fm:meta readEditable desc=live text + resolved tag of the contentEditable that fired a key event
%% fm:meta readEditable i0.accepts=event: KeyEventData.nativeEvent
%% fm:meta readEditable i0.returns=value: string, tag: TextElement.Tag
%% fm:meta isEmpty name=isEmptyEditable
%% fm:meta isEmpty desc=true when the fired contentEditable has no text
%% fm:meta isEmpty i0.accepts=event: KeyEventData.nativeEvent
%% fm:meta isEmpty i0.returns=boolean

%% ── blockDefinitions.ts (sibling module, top level) ──────────────────────────
%% fm:meta blockDefs name=blockDefinitions
%% fm:meta blockDefs desc=catalog of insertable blocks; read by LeftPanel (lists) and BlockManager (resolves a panel id)
%% fm:meta blockDefs state=BLOCK_DEFINITIONS: BlockSpec[]
%% fm:meta blockDefs i0.name=findBlockDefinition
%% fm:meta blockDefs i0.accepts=id: string
%% fm:meta blockDefs i0.returns=BlockSpec | undefined

%% ── EXTERNAL collaborators (top level) ───────────────────────────────────────
%% fm:meta grid name=grid (layout manager)
%% fm:meta grid desc=external; snapToGrid + GRID_UNIT / PAGE_X for placing new blocks
%% fm:meta wsLayout name=workspaceLayout (layout manager)
%% fm:meta wsLayout desc=external; measuredBlockHeight + NEW_BLOCK_* sizing constants
%% fm:meta dbFactory name=databaseFactory (components)
%% fm:meta dbFactory desc=external; makeDatabaseConfig / makeDatabaseRow + DB_BLOCK_DEFAULT_H
%% fm:meta wsStore name=useWorkspaceStore (components)
%% fm:meta wsStore desc=external; setPendingFocus caret intent via getState()

%% ── kinds ────────────────────────────────────────────────────────────────────
%% kind bm class
%% kind rMouse function
%% kind rKey function
%% kind rLife function
%% kind atClick function
%% kind fromPanel function
%% kind atBottom function
%% kind below function
%% kind addBlock function
