%% kind wsStore store

%% ── containment: every private node lives INSIDE bm (drill-in) ───────────────
%% parent rMouse bm
%% parent rKey bm
%% parent rLife bm
%% parent atClick bm
%% parent fromPanel bm
%% parent atBottom bm
%% parent below bm
%% parent addBlock bm
%% parent del bm
%% parent addRow bm
%% parent toggle bm
%% parent createDb bm
%% parent commit bm
%% parent lowest bm
%% parent makeBlock bm
%% parent insertAfter bm
%% parent readEditable bm
%% parent isEmpty bm

  bm["BlockManager"]

  rMouse("_receiveMouseFlat")
  rKey("_receiveKeyFlat")
  rLife("_receiveLifecycleFlat")
  atClick("_createAtClick")
  fromPanel("_createFromPanel")
  atBottom("_createAtBottom")
  below("_createBelow")
  addBlock("_addBlock")
  del("_deleteBlock")
  addRow("_addRow")
  toggle("_toggleCell")
  createDb("createDatabase")
  commit("_commitText")
  lowest("lowestPlacedBottom")
  makeBlock("makeBlock")
  insertAfter("insertAfter")
  readEditable("readEditable")
  isEmpty("isEmptyEditable")

  blockDefs["blockDefinitions"]

  subgraph external ["external collaborators"]
    grid("grid")
    wsLayout("workspaceLayout")
    dbFactory[("databaseFactory")]
    wsStore[("useWorkspaceStore")]
  end

  %% ── inner spine (visible on drill-in): router -> handler ────────────────────
  rMouse -->|workspace-click| atClick
  rMouse -->|panel-block-click| fromPanel
  rMouse -->|database-add-row| addRow
  rMouse -->|cell-toggle| toggle
  rKey -->|Cmd+Shift+D| createDb
  rKey -->|Enter| below
  rKey -->|Backspace| del
  rLife -->|blur / input| commit
  fromPanel -->|database spec| createDb
  fromPanel -->|text spec| atBottom

  %% ── inner references (dotted): shared builders + readers ────────────────────
  atClick -.->|addBlock| addBlock
  atBottom -.->|addBlock| addBlock
  atClick -.->|makeBlock| makeBlock
  atBottom -.->|makeBlock| makeBlock
  below -.->|makeBlock| makeBlock
  createDb -.->|makeBlock| makeBlock
  atBottom -.->|lowestPlacedBottom| lowest
  createDb -.->|lowestPlacedBottom| lowest
  below -.->|insertAfter| insertAfter
  below -.->|readEditable| readEditable
  del -.->|isEmptyEditable| isEmpty

  %% ── cross-level references: inner node -> off-level endpoint (boundary stub) ─
  fromPanel -.->|findBlockDefinition| blockDefs
  atClick -.->|snap geometry| grid
  below -.->|measure height + snap| wsLayout
  addRow -.->|row builder| dbFactory
  createDb -.->|db config + cells| dbFactory
  below -.->|setPendingFocus| wsStore
  del -.->|setPendingFocus| wsStore
