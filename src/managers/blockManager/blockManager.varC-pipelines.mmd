%% fm:meta bm i2.accepts=draft: DocDraft
%% fm:meta bm i2.returns=DocDraft
%% fm:meta bm i3.name=receiveLifecycleEvent
%% fm:meta bm i3.accepts=draft: DocDraft
%% fm:meta bm i3.returns=DocDraft

