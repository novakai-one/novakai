%% ── kinds ────────────────────────────────────────────────────────────────────
%% kind bm class
%% kind rMouse function
%% kind atClick function
%% kind fromPanel function
%% kind atBottom function
%% kind addRow function
%% kind toggle function
%% kind rKey function
%% kind below function
%% kind del function
