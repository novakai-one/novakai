  layoutManager["LayoutManager"]

  subgraph layoutModule ["module"]
    workspaceLayout("workspaceLayout")
  end

  subgraph collisionGroup ["collision-manager"]
    collisionManager("CollisionManager")
  end

  subgraph gridGroup ["grid"]
    grid("grid")
  end

  subgraph storeGroup ["store"]
    useLayoutStore[("useLayoutStore")]
  end

  %% ── spine: tidy delegates into the placement helpers, then to collision ─────
  layoutManager -->|resolveFileCollisions + orderByPosition| workspaceLayout
  workspaceLayout -->|resolveCollisions| collisionManager

  %% ── references (dotted): grid math + shared types ──────────────────────────
  workspaceLayout -.->|snap + row/px math| grid
  layoutManager -.->|LayoutItem type| workspaceLayout
