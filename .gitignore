node_modules
dist
*.log
.DS_Store
.vite
src/**/*.js

# buildspec pipeline — generated stub output (regenerate with `npm run spec:stubs`)
tools/buildspec/__demo_out/
*.extracted.mmd
# TypeScript incremental build cache
tsconfig.tsbuildinfo
*.tsbuildinfo

# Generated source-viewer data — NEVER commit. Contains your real source code.
# Users load their own bodies.json client-side via the Bodies button instead.
public/bodies.json
extracted.bodies.json
extracted.mmd
*.bodies.json

# quiz session state (AUD5/F-03): answers are per-session; the pass artifact
# is bound to the local map hash — neither belongs in the repo (a committed
# answers file was the AUD2 A4 replay surface).
.quiz-answers.json
.novakai-quiz-pass.json
# M10 turn-gate one-free-retry marker: session-local, same class as the quiz state above.
# The -<agentId> variants are per-sidechain markers; .novakai-reminders.json is the
# reminder-hook throttle counter — all session-local state, never committed.
.novakai-turn-gate.json
.novakai-turn-gate-*.json
.novakai-reminders.json
.novakai-gate-debug
.novakai-gate-debug.jsonl
# C9 subagent-stop verdicts: per-change machine verdicts + drift reports written
# on SubagentStop. Working-tree noise, never committed (a committed verdict could
# lie about HEAD — same rule as public/contracts/ below).
.novakai-verdicts/

# compliance metrics log (M2b): session/machine-local telemetry, same class as
# the quiz artifacts above. A committed append-only log guarantees EOF merge
# conflicts between concurrent branches plus unbounded growth; the emitter
# mkdirs this on first write and the summarizer is green on a fresh clone.
docs/novakai/metrics/

# M6 readability baselines: temp declaration-emit output used by
# .readability/scripts/api-surface.mjs — regenerated on every run, never committed.
.readability/.dts-tmp/

# Playwright (J1) — local run output, never committed.
test-results/
playwright-report/

# K4 Contracts tab (SPEC_CONTRACTS.md §1): generated packet/verdict artifacts
# and a locally-regenerated index are working-tree noise, never committed — a
# committed verdict could lie about HEAD. The committed baseline stays
# {"v":1,"files":[]}.
public/contracts/*
!public/contracts/index.json
