%% kind plan module

  novakaiBuildspec["buildspec"]
  novakaiIntegrity["integrity"]
  novakaiUnderstand["understand"]
  novakaiContinuity["continuity"]
  novakaiPlanApprove["plan+approve"]
  novakaiContractSpine["contract-spine"]

  subgraph AppSurface ["app surface (src/)"]
    mermaid["mermaid"]
    frontmatter["frontmatter"]
    state["state"]
    files["files"]
    diff["diff"]
    slice["slice"]
    plan["plan"]
  end

  %% ---- subsystem-level flow (the loop) ----
  novakaiUnderstand -->|onboard shells verify chain| novakaiIntegrity
  novakaiUnderstand -->|onboard shows roadmap| novakaiContinuity
  novakaiIntegrity -.->|gate + extract| novakaiBuildspec
  novakaiContinuity -.->|status reuses extract| novakaiBuildspec
  novakaiPlanApprove -.->|cert/approve reuse pipeline| novakaiBuildspec
  novakaiContractSpine -.->|verify/waves shell status| novakaiContinuity
  novakaiContractSpine -.->|contract uses plan-check| novakaiPlanApprove
  novakaiContractSpine -.->|contract/verify reuse acceptance| novakaiBuildspec

  %% ---- tooling -> app surface (the blast radius) ----
  novakaiBuildspec -.->|two-parser conformance| mermaid
  novakaiBuildspec -.->|mirrors helpers| state
  novakaiBuildspec -.->|writes bodies.json| files
  novakaiPlanApprove -.->|parallels core/plan| plan
  novakaiContractSpine -.->|downstreamCone| plan
