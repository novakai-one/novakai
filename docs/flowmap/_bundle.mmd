%% fm:meta clipboard name=clipboard
%% fm:meta clipboard desc=in-memory clipboard; copySel, paste, duplicate.
%% fm:meta keyboard name=keyboard
%% fm:meta keyboard desc=global key + wheel input; routes shortcuts to the right verb.
%% fm:meta inlineEdit name=inlineEdit
%% fm:meta inlineEdit desc=contenteditable inline label editing (double-click / Enter).
%% fm:meta contextMenu name=contextMenu
%% fm:meta contextMenu desc=builds + positions the right-click context menu and runs its actions.
%% fm:meta view name=view
%% fm:meta view desc=drill-in navigation; owns ctx.view.container and the breadcrumb (enter/step-up).
%% fm:meta mermaid name=mermaid
%% fm:meta mermaid desc=two-way Mermaid text<->model; serialise the model to flowchart text and parse edited text back into model ops.
