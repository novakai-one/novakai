  main -->|1 build ctx| context
  main -->|2 createState| state
  main -->|3 initPersistence| persistence
  main -->|4 initCamera| camera
  main -->|5 initHistory| history
  main -.->|createRuntime on ctx| runtime
  main -.->|loadPrefs / savePrefs| persistence
  main -.->|restore-or-seed| seed
  seed -.->|writes nodes/edges| state
  context -.->|holds| state
  context -.->|holds| runtime
  camera -.->|reads level bounds| state
  camera -.->|Z_MIN/Z_MAX| config
  camera -.->|drawMinimap / persist| context
  persistence -.->|reads/writes| state
  persistence -.->|LS_KEY / DEFAULT_PREFS| config
  persistence -.->|normalize on load| frontmatter
  history -.->|snapshots| state
  history -.->|render/sync/persist| context
  validate -.->|checks| state
  validate -.->|over| types
  frontmatter -.->|builds/parses| types
  state -.->|nodes are| types
  state -.->|nodeFill / DEFAULTS| config
  camera -.->|returns| CameraApi
  validate -.->|emits| Issue
  frontmatter -.->|parses| TypeRef
