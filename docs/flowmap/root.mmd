  workspace -->|1 receive* draft| blockManager
  workspace -->|2 receive* draft| selection
  workspace -->|3 receive* draft| drag
  workspace -->|4 receive* draft| layout
  workspace -.->|commit setDataSet| store
  store -.->|buildDraft reads state| workspace
  workspace -.->|commit saveDocument| storage
  workspace -.->|layoutKey| model
  blockManager -.->|in/out| DocDraft
  selection -.->|in/out| DocDraft
  drag -.->|in/out| DocDraft
  layout -.->|in/out| DocDraft
  DocDraft -.->|flat view| DocShape
  workspace -.->|placeCaret| dom
  drag -.->|style.top, measure| dom
  layout -.->|measuredBlockHeight| dom
  selection -.->|CSS.highlights| dom
  blockManager -.->|draftToFlat / foldIntoDraft| draft
  drag -.->|draftToFlat / foldIntoDraft| draft
  layout -.->|draftToFlat / foldIntoDraft| draft
  workspace -.->|buildDraft| draft
  draft -.->|builds + folds| DocDraft
  workspace -->|renders per block| dragContainer
  dragContainer -.->|cbMouseEvent (drag-handle-mouse-down)| workspace
  dragContainer -.->|isDragging guard| drag
  workspace -->|block content via registry| contentArea
  contentArea -.->|cb mouse/key/lifecycle up| workspace
  contentArea -.->|caret read + text sync| dom
  storage -.->|Supabase client| supabase
  leftPanel -.->|dispatch left-panel-block-mouse-click| workspace
  leftPanel -.->|add file: setDataSet| store
  leftPanel -.->|add file: saveDocument| storage
  leftPanel -.->|lists catalog| blockDefs
  leftPanel -.->|reads leftPanelOpen| layoutStore
  leftPanel -->|renders| panelChrome
  blockManager -.->|builds from catalog| blockDefs
  rightPanel -.->|setTheme / setAccent (repaint :root)| themeStore
  rightPanel -.->|setPageWidth / reads pageWidth| layoutStore
  auth -.->|signIn/Up/Out + session| supabase
  workspace -.->|block dispatch by component name| componentRegistry
  componentRegistry -.->|ContentArea| contentArea
  componentRegistry -.->|CanvasArea| canvasArea
  componentRegistry -.->|DatabaseArea| databaseArea
  workspace -.->|route trigger: TriggerWord| TriggerWord
  leftPanel -.->|panel-block trigger| TriggerWord
  workspace -->|renders DatabaseArea block| databaseArea
  workspace -->|renders CanvasArea block| canvasArea
  databaseArea -.->|databases[id]| store
  databaseArea -.->|cell renders| contentArea
  databaseArea -.->|cb up| workspace
  blockManager -.->|insert DatabaseArea: makeDatabaseConfig| databaseFactory
  databaseFactory -.->|makeTextElement| model
  themeStore -.->|applyTheme :root| dom
  themeStore -.->|persist/hydrate workspaces.theme| supabase
