%% fm:meta model desc=factories + keys (makeTextElement, layoutKey, databaseKey, CHECKBOX_CHECKED)
%% fm:meta store name=useWorkspaceStore
%% fm:meta store desc=Zustand; in-memory rendered doc state (fragment is canonical)
