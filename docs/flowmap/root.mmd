%% fm:meta dom name=dom
%% fm:meta dom desc=live DOM read/write that bypasses React (direct style writes, getBoundingClientRect, CSS.highlights, caret) — flagged for boundary review
%% fm:meta layoutStore name=useLayoutStore
%% fm:meta layoutStore desc=UI chrome state — leftPanelOpen, rightPanelOpen, pageWidth. DISTINCT from the LayoutManager class (layout). Read by leftPanel + rightPanel.
%% fm:meta blockDefs name=BLOCK_DEFINITIONS
%% fm:meta blockDefs desc=insertable-block catalog (managers/blockManager/blockDefinitions). leftPanel lists it; BlockManager builds from it — single source, no drift.
%% fm:meta themeStore name=useThemeStore
%% fm:meta themeStore desc=theme tokens — themeId + accentHex; setTheme/setAccent repaint :root live. Written by rightPanel. Dedicated theme container deferred (TODO 3).
%% fm:meta panelChrome name=Panel
%% fm:meta panelChrome desc=shared panel render chrome (panels/shared/panel); rendered by leftPanel. Own fragment deferred.
%% fm:meta componentRegistry name=COMPONENT_REGISTRY
%% fm:meta componentRegistry desc=block component-name -> React component (ContentArea, CanvasArea, DatabaseArea); WSA dispatches each block to its renderer through this
%% fm:meta TriggerWord name=TriggerWord
%% fm:meta TriggerWord desc=the trigger-string union (types/trigger-words); every origin tags its event with one; managers act off it
%% fm:meta canvasArea name=CanvasArea
%% fm:meta canvasArea desc=placeholder block component (renders a bare canvas); real drawing tools ship later. No fragment.
%% fm:meta draft name=draft
%% fm:meta draft desc=uniform payload plumbing (fragment is canonical); buildDraft / draftToFlat / foldIntoDraft. NOTE selection keeps its own copy in core/docShape — divergence
